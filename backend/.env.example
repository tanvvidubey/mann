# Use port 5433 when using docker-compose (host port); 5432 when using local Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mann
JWT_SECRET=your-secret-key-change-in-production
WHISPER_MODEL=small
CHROMA_PERSIST_DIR=./chroma_data
# Lightest default; use e.g. phi, mistral for better quality
OLLAMA_MODEL=tinyllama
# Optional: stronger model for weekly suggestions only (better accuracy than tinyllama)
# OLLAMA_MODEL_SUGGESTIONS=mistral
# Set ANONYMIZED_TELEMETRY=False in env to avoid ChromaDB telemetry errors in logs

# Email (verification, welcome, PIN change). Leave empty to skip sending.
